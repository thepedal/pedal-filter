<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <OutputType>Library</OutputType>
    <!--
      The assembly name MUST contain ".NET" so ReBuzz recognises it
      as a managed (dotnet) machine.
    -->
    <AssemblyName>Pedal Filter.NET</AssemblyName>
    <RootNamespace>WDE.PedalFilter</RootNamespace>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <Optimize>true</Optimize>

    <!--
      Output goes straight into the ReBuzz Effects gear folder.
      Override BuzzDir on the command line if ReBuzz lives elsewhere:
        dotnet build PedalFilter.csproj -c Release /p:BuzzDir="D:\ReBuzz"
    -->
    <BuzzDir Condition="'$(BuzzDir)' == ''">C:\Program Files\ReBuzz</BuzzDir>
    <OutputPath>$(BuzzDir)\Gear\Effects</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
  </PropertyGroup>

  <!--
    ReBuzz managed-machine API DLLs – not on NuGet, they ship with ReBuzz.
    Private=false means they will NOT be copied to the output folder
    (ReBuzz already has them at runtime).
  -->
  <ItemGroup>
    <!-- Buzz.MachineInterface: IBuzzMachine, MachineDecl, ParameterDecl,
                                IBuzzMachineHost, Sample, WorkModes          -->
    <Reference Include="ReBuzz">
      <HintPath>$(BuzzDir)\ReBuzz.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- BuzzGUI types used by the managed machine infrastructure -->
    <Reference Include="BuzzGUI.Interfaces">
      <HintPath>$(BuzzDir)\BuzzGUI.Interfaces.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
